{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capabilities for the library and document windows",
  "windows": ["library", "book-*"],
  "remote": {
    "urls": ["http://127.0.0.1:4000/*"]
  },
  "permissions": [
    "core:default",
    "opener:default",
    "core:window:allow-start-dragging"
  ]
}
