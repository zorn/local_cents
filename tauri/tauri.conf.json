{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "local-cents",
  "version": "0.1.0",
  "identifier": "com.example.LocalCents",
  "build": {
    "beforeBuildCommand": "MIX_ENV=prod mix do compile + assets.deploy + release --overwrite --path tauri/target/rel"
  },
  "app": {
    "withGlobalTauri": true,
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "resources": {
      "target/rel": "rel"
    },
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
